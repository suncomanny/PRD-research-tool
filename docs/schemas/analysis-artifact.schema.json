{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sunco.local/prd-research-tool/analysis-artifact.schema.json",
  "title": "Analysis Artifact",
  "description": "Top-level file shape for row-level pricing, spec, and performance-estimation analysis.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "artifact_status",
    "batch_id",
    "row_number",
    "ideation_name",
    "expected_owner",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artifact_type": {
      "type": "string",
      "const": "analysis"
    },
    "artifact_status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "complete",
        "blocked"
      ]
    },
    "batch_id": {
      "type": "string"
    },
    "row_number": {
      "type": "integer"
    },
    "ideation_name": {
      "type": "string"
    },
    "expected_owner": {
      "type": "string",
      "const": "codex"
    },
    "source_channel_group": {
      "type": [
        "string",
        "null"
      ]
    },
    "packet_file": {
      "type": [
        "string",
        "null"
      ]
    },
    "normalized_file": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "object"
    },
    "pricing_analysis": {
      "type": "object"
    },
    "spec_coverage": {
      "type": "object"
    },
    "performance_estimation": {
      "type": "object"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string"
    }
  }
}
